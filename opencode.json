{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "tailwindcss-mcp": {
      "type": "local",
      "command": ["npx", "-y", "tailwindcss-mcp"],
      "enabled": true
    },
    "tailwindcss-docs-mcp": {
      "type": "local",
      "command": ["npx", "-y", "tailwindcss-docs-mcp"],
      "enabled": true
    }
  }
}
