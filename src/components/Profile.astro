---
import profile from '../data/profile.json'
---
<header id="inicio" class="section">
  <div class="profile-header">
    <img src="/assets/perfil.jpg" alt="Alonso Jos\u00e9 Su\u00e1rez Reza" class="profile-img">
    <div class="profile-text">
      <h1>{profile.name}</h1>
      <p class="subtitle" data-i18n="hero-sub"><strong>Desarrollador de software</strong><br>Full Stack · Agentes · Data</p>
      <div class="badges-wrapper" id="badges-container">
        <div class="badges">
          {profile.badges.map(b => (
            <span class={`badge ${b.class}`}>{b.label}</span>
          ))}
        </div>
        <div class="badges tools-badges">
          {profile.toolBadges.map(b => (
            <span class={`badge ${b.class}`}>{b.label}</span>
          ))}
        </div>
      </div>
      <a href={profile.cvPath} class="cv-cta-button" download>
        <span class="icon">📄</span>
        <span class="text" data-i18n="cv-text-h">Descargar Curriculum Vitae (PDF)</span>
      </a>
    </div>
  </div>
</header>
