---
import profile from '../data/profile.json'
---
<header id="inicio" class="profile-header">
  <div class="flex items-center gap-7 py-5 
              max-[650px]:flex-col max-[650px]:gap-5 
              max-[650px]:text-center">
    <img src="/assets/perfil.jpg" alt="Alonso José Suárez Reza"
         class="profile-img">
    <div>
      <h1 class="profile-name">{profile.name}</h1>
      <p class="subtitle my-1.5 mb-[15px] 
                text-[1.1em] text-text-muted" data-i18n="hero-sub"><strong>Desarrollador de software</strong><br>Full Stack · Agentes · Data</p>
      <div class="flex flex-wrap gap-0" id="badges-container">
        <div>
          {profile.badges.map(b => (
            <span class={`badge ${b.class}`}>{b.label}</span>
          ))}
        </div>
        <div class="tools-badges">
          {profile.toolBadges.map(b => (
            <span class={`badge ${b.class}`}>{b.label}</span>
          ))}
        </div>
      </div>
      <div style="position: relative; z-index: 1;">
        <a href={profile.cvPath} class="cv-btn" download>
          <span>📄</span>
          <span data-i18n="cv-text-h">Descargar Curriculum Vitae (PDF)</span>
        </a>
      </div>
    </div>
  </div>
</header>
