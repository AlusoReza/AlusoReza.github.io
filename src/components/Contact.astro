---
import lang from '../data/lang.json'
const l = 'es'
const t = (key) => lang[l]?.[key] || ''
---
<footer id="contacto" class="contact-links">
  <h2 data-i18n="sec-cont"
    class="section-title justify-center border-b-0 
           mb-5 text-[1.8em]">{t('sec-cont')}</h2>
  <p class="contact-subtitle" data-i18n="cont-sub" set:html={t('cont-sub')}></p>
  <a href="/assets/Alonso_Reza_CV.pdf" class="cv-btn cv-btn-accent" download>
    <span>📄</span>
    <span data-i18n="cv-text-f">Descargar Curriculum Vitae (PDF)</span>
  </a>
  <div class="flex flex-wrap justify-center gap-5 
              max-[480px]:flex-col max-[480px]:items-center">
    <a href="https://www.linkedin.com/in/alonsoreza" target="_blank" rel="noopener noreferrer"
       class="social-btn">
      <span>LinkedIn</span>
      <small data-i18n="soc-li">{t('soc-li')}</small>
    </a>
    <a href="https://github.com/AlusoReza" target="_blank" rel="noopener noreferrer"
       class="social-btn">
      <span>GitHub</span>
      <small data-i18n="soc-gh">{t('soc-gh')}</small>
    </a>
  </div>
</footer>
