---
import sections from '../data/sections.json'
import skills from '../data/skills.json'
const l = 'es'
const t = (key) => sections[l]?.[key] || ''
const tl = (obj) => obj?.[l] || ''
const languages = skills.languages || []
const tools = skills.tools || []
const personality = skills.personality || []
---
<div data-page="hab" class="page">
    {personality.length > 0 && (
    <>
      <h2 class="section-title reveal" data-i18n="sec-hab-personal">Perfil Profesional</h2>
      <p class="personality-note reveal" data-i18n="hab-note">{t('hab-note')}</p>
      <p class="personality-note reveal" data-i18n="hab-ai" set:html={t('hab-ai')}></p>
      <div class="skills-personality-grid" data-section="skills">
        {personality.map(s => (
          <div class="skill-personality-item">
            <strong>{tl(s.title)}</strong>
            <p>{tl(s.description)}</p>
          </div>
        ))}
      </div>
    </>
  )}
</div>
