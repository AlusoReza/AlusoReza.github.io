---
import sections from '../data/sections.json'
import projects from '../data/projects.json'
const l = 'es'
const t = (key) => sections[l]?.[key] || ''
const tl = (obj) => obj?.[l] || ''
---
<div data-page="proy" class="page">
  <h2 class="section-title reveal" data-i18n="sec-proy">Proyecto Destacado</h2>
  <div data-section="projects">
  {projects.map(proj => (
    <div class="project-card">
      <div class="project-header">
        <div class="project-dots"><span></span><span></span><span></span></div>
        <span class="project-prompt">$</span>
        <span class="project-title">{proj.title}</span>
      </div>
      <p class="project-desc">{tl(proj.description)}</p>
      {proj.stack && proj.stack.length > 0 && (
        <div class="stack-tags">
          {proj.stack.map(tag => (
            <span class="stack-tag">{tag}</span>
          ))}
        </div>
      )}
      {proj.links && (
        <div class="project-links">
          {proj.links.map(link => (
            <a href={link.url} target="_blank" rel="noopener noreferrer" class="project-link">{tl(link.text)}</a>
          ))}
        </div>
      )}
    </div>
  ))}
  </div>
</div>
