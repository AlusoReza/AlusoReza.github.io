---
import lang from '../data/lang.json'
import certificates from '../data/certificates.json'
const l = 'es'
const t = (key) => lang[l]?.[key] || ''
const tl = (obj) => obj?.[l] || ''
const empty = !certificates || certificates.length === 0
---
<section id="certificados" style={empty ? 'display:none' : ''} class="reveal section-reveal">
  <h2 data-i18n="sec-cert"
    class="section-title">{t('sec-cert')}</h2>
  <div data-section="certificates">
    {certificates.map(item => (
      <div class="card-item">
        <div class="card-header">
          <strong class="card-title">{tl(item.title)}</strong>
          {item.date && <span class="card-date">{tl(item.date)}</span>}
        </div>
        {item.institution && <p class="card-sub">{tl(item.institution)}</p>}
        {item.description && <p class="card-desc">{tl(item.description)}</p>}
      </div>
    ))}
  </div>
</section>
