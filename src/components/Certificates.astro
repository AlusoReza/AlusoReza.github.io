---
import sections from '../data/sections.json'
import certificates from '../data/certificates.json'
const l = 'es'
const t = (key) => sections[l]?.[key] || ''
const tl = (obj) => obj?.[l] || ''
---
<div data-page="cert" class="page">
  <h2 class="section-title reveal" data-i18n="sec-cert">Certificados</h2>
  <div data-section="certificates">
  {certificates.map(item => (
    <div class="card-item">
      <div class="card-header">
        <strong class="card-title">{tl(item.title)}</strong>
        {item.date && <span class="card-date">{tl(item.date)}</span>}
      </div>
      {item.tags && item.tags.length > 0 && (
        <div class="card-tags">
          {item.tags.map(tag => <span class="card-tag">{tl(tag)}</span>)}
        </div>
      )}
      {item.institution && <p class="card-sub">{tl(item.institution)}</p>}
      {item.description && <p class="card-desc">{tl(item.description)}</p>}
    </div>
  ))}
  </div>
</div>
