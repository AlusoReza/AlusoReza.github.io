---
import lang from '../data/lang.json'
import experience from '../data/experience.json'
import certificates from '../data/certificates.json'
const l = 'es'
const t = (key) => lang[l]?.[key] || ''
const showExperience = experience && experience.length > 0
const showCertificates = certificates && certificates.length > 0
const links = [
  { href: '#inicio', key: 'nav-inicio' },
  { href: '#sobre-mi', key: 'nav-sobre' },
  { href: '#habilidades', key: 'nav-hab' },
  { href: '#proyectos', key: 'nav-proy' },
  { href: '#estudios', key: 'nav-est' },
  ...(showExperience ? [{ href: '#experiencia', key: 'nav-exp' }] : []),
  ...(showCertificates ? [{ href: '#certificados', key: 'nav-cert' }] : []),
  { href: '#contacto', key: 'nav-cont' },
]
---
<nav class="nav-bar">
  <div class="mx-auto max-w-[850px] px-5">
    <div class="nav-container">
      <button class="nav-toggle" id="nav-toggle" aria-label="Menú">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-links" id="nav-links">
        {links.map(link => (
          <a href={link.href} data-i18n={link.key}
             class="nav-link">{t(link.key)}</a>
        ))}
        <div class="lang-switcher">
          <button data-lang="es" class="lang-btn" id="btn-es">ES</button>
          <span class="text-xs text-border">|</span>
          <button data-lang="en" class="lang-btn" id="btn-en">EN</button>
        </div>
      </div>
    </div>
  </div>
</nav>
<div class="nav-overlay" id="nav-overlay"></div>
