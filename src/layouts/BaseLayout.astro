---
import Profile from '../components/Profile.astro'
import nav from '../data/nav.json'
import about from '../data/about.json'
import sections from '../data/sections.json'
import skills from '../data/skills.json'
import education from '../data/education.json'
import projects from '../data/projects.json'
import experience from '../data/experience.json'
import certificates from '../data/certificates.json'
import profile from '../data/profile.json'
import '../styles/global.css'

const { title, description } = Astro.props
const lang = {
  es: { ...nav.es, ...about.es, ...sections.es },
  en: { ...nav.en, ...about.en, ...sections.en }
}
const dataBundle = JSON.stringify({ lang, skills, education, projects, experience, certificates, profile })
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content="/assets/perfil.jpg">
  <meta property="og:url" content="https://alusoreza.github.io/">
  <meta name="google-site-verification" content="wR-Ww7Z3Js_kmiCYxoddSnZxfFNydHYLBu6iaO8ykUY" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body data-data={dataBundle}>
  <canvas id="particle-canvas"></canvas>
  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Menú">
    <span></span><span></span><span></span>
  </button>
  <div class="sidebar-overlay" id="sidebar-overlay"></div>
  <div class="app-layout">
    <aside class="sidebar" id="sidebar">
      <Profile />
    </aside>
    <main class="content" id="content">
      <div class="content-body">
        <div class="lang-switcher-floating" id="lang-switcher-floating">
          <button class="sidebar-lang-btn" data-lang="es">ES</button>
          <button class="sidebar-lang-btn" data-lang="en">EN</button>
        </div>
        <slot />
        <p class="site-footer" data-i18n="footer">Diseñado y construido por Alonso Suárez Reza</p>
      </div>
    </main>
  </div>
  <a href="#" id="back-to-top" class="back-to-top" title="Volver arriba">&uarr;</a>
  <script src="../scripts/client.js"></script>
</body>
</html>
